---
import Goal from '../components/icons/Goal.astro';
import MapPin from '../components/icons/MapPin.astro';
import RsvpSection from '../components/RsvpSection.astro';
import Separator from '../components/Separator.astro';
import Toast from '../components/Toast.astro';
import TransportSection from '../components/TransportSection.astro';
import VenueSection from '../components/VenueSection.astro';
import WeddingCountdown from '../components/WeddingCountdown.astro';
import WeddingHero from '../components/WeddingHero.astro';
import WeddingTimeline from '../components/WeddingTimeline.astro';
import Layout from '../layouts/Layout.astro';

export const prerender = false;
---

<Layout>
  <WeddingHero />
  <WeddingCountdown />
  <VenueSection />
  <Separator />
  <WeddingTimeline />
  <Separator />
  <TransportSection
    title="Autobús de ida"
    stops={[
      {
        hour: '18:50',
        title: 'Novelda',
        description: 'Parada del Manila',
        Icon: MapPin,
      },
      {
        hour: '19:05',
        title: 'Monóvar',
        description: 'Parada del Salitre (a mitad de calle)',
        Icon: MapPin,
      },
    ]}
  />
  <Separator />
  <TransportSection
    title="Autobús de vuelta"
    stops={[
      { hour: '04:10', title: 'Sale del restaurante', Icon: Goal },
      { title: 'Monóvar', description: 'Primera parada', Icon: MapPin },
      { title: 'Novelda', description: 'Segunda parada', Icon: MapPin },
    ]}
  />
  <div class="px-6 pb-20 md:pb-28 -mt-4 bg-ivory text-center">
    <p
      class="text-muted-foreground font-body text-sm leading-relaxed max-w-md mx-auto"
    >
      Os pedimos que estéis en la parada con unos minutos de antelación para
      que podamos salir puntuales.
    </p>
  </div>
  <Separator />
  <RsvpSection />
  <Toast />
</Layout>
