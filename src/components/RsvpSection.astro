---
import { actions } from 'astro:actions';

const result = Astro.getActionResult(actions.confirmAssist);

result;
---

<section id="rsvp" class="section-padding bg-ivory">
  <div class="max-w-xl mx-auto">
    <div class="text-center mb-12" style="opacity: 1; transform: none;">
      <h2 class="font-script text-5xl md:text-6xl text-foreground mb-2">
        Confirma tu asistencia
      </h2>
      <p class="text-muted-foreground font-body tracking-wide"
        >Esperamos contar contigo</p
      >
    </div>
    <form
      class="bg-card/90 backdrop-blur-sm border border-border rounded-sm p-8 space-y-6 shadow-soft"
      style="opacity: 1; transform: none;"
      action={actions.confirmAssist}
      method="POST"
    >
      <div>
        <label
          class="text-sm leading-none peer-disabled:cursor-not-allowed peer-disabled:opacity-70 text-foreground font-medium"
          for="full_name"
        >
          Nombre completo *
        </label>
        <input
          class="flex h-10 w-full rounded-md border px-3 py-2 text-base ring-offset-background file:border-0 file:bg-transparent file:text-sm file:font-medium file:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50 md:text-sm mt-2 bg-background border-border text-foreground placeholder:text-muted-foreground focus:border-primary"
          id="full_name"
          name="full_name"
          required=""
          placeholder="Tu nombre"
          value=""
        />
      </div>
      <div>
        <label
          class="text-sm leading-none peer-disabled:cursor-not-allowed peer-disabled:opacity-70 text-foreground font-medium"
          for="email"
        >
          Email (opcional)
        </label>
        <input
          type="email"
          class="flex h-10 w-full rounded-md border px-3 py-2 text-base ring-offset-background file:border-0 file:bg-transparent file:text-sm file:font-medium file:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50 md:text-sm mt-2 bg-background border-border text-foreground placeholder:text-muted-foreground focus:border-primary"
          id="email"
          name="email"
          placeholder="tu@email.com"
          value=""
        />
      </div>
      <div>
        <label
          class="text-sm leading-none peer-disabled:cursor-not-allowed peer-disabled:opacity-70 text-foreground font-medium"
          >¿Asistirás? *
        </label>
        <div class="flex gap-6 mt-3">
          <label
            class="flex items-center gap-2 font-medium text-sm cursor-pointer text-foreground"
          >
            <input
              type="radio"
              id="attending-yes"
              name="attending"
              value="yes"
              class="peer sr-only"
              checked
            />
            <span
              class="h-4 w-4 shrink-0 rounded-full border border-primary bg-background ring-offset-background transition-colors peer-focus-visible:ring-2 peer-focus-visible:ring-ring peer-focus-visible:ring-offset-2 peer-checked:bg-primary peer-checked:ring-2 peer-checked:ring-white peer-checked:ring-inset"
            ></span>
            <span>Sí, asistiré</span>
          </label>
          <label
            class="flex items-center gap-2 font-medium text-sm cursor-pointer text-foreground"
          >
            <input
              type="radio"
              id="attending-no"
              name="attending"
              value="no"
              class="peer sr-only"
            />
            <span
              class="h-4 w-4 shrink-0 rounded-full border border-primary bg-background ring-offset-background transition-colors peer-focus-visible:ring-2 peer-focus-visible:ring-ring peer-focus-visible:ring-offset-2 peer-checked:bg-primary peer-checked:ring-2 peer-checked:ring-white peer-checked:ring-inset"
            ></span>
            <span>No podré asistir</span>
          </label>
        </div>
      </div>
      <fieldset id="attendance-details" class="space-y-6 disabled:opacity-60">
        <div>
          <label
            class="text-sm leading-none peer-disabled:cursor-not-allowed peer-disabled:opacity-70 text-foreground font-medium"
            for="guest_count">Número de invitados (incluyéndote)</label
          ><input
            type="number"
            class="flex h-10 rounded-md border px-3 py-2 text-base ring-offset-background file:border-0 file:bg-transparent file:text-sm file:font-medium file:text-foreground placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50 md:text-sm mt-2 w-24 bg-background border-border text-foreground focus:border-primary"
            id="guest_count"
            name="guest_count"
            min="1"
            max="10"
            value="1"
          />
        </div>
        <div class="space-y-4">
          <div>
            <label
              class="text-sm leading-none peer-disabled:cursor-not-allowed peer-disabled:opacity-70 text-foreground font-medium"
              >¿Necesitaréis bus? *</label
            >
            <div class="flex gap-6 mt-3">
              <label
                class="flex items-center gap-2 font-medium text-sm cursor-pointer text-foreground"
              >
                <input
                  type="radio"
                  id="bus-required-yes"
                  name="bus_required"
                  value="yes"
                  class="peer sr-only"
                />
                <span
                  class="h-4 w-4 shrink-0 rounded-full border border-primary bg-background ring-offset-background transition-colors peer-focus-visible:ring-2 peer-focus-visible:ring-ring peer-focus-visible:ring-offset-2 peer-checked:bg-primary peer-checked:ring-2 peer-checked:ring-white peer-checked:ring-inset"
                ></span>
                <span>Sí, iremos en bus</span>
              </label>
              <label
                class="flex items-center gap-2 font-medium text-sm cursor-pointer text-foreground"
              >
                <input
                  type="radio"
                  id="bus-required-no"
                  name="bus_required"
                  value="no"
                  class="peer sr-only"
                  checked
                />
                <span
                  class="h-4 w-4 shrink-0 rounded-full border border-primary bg-background ring-offset-background transition-colors peer-focus-visible:ring-2 peer-focus-visible:ring-ring peer-focus-visible:ring-offset-2 peer-checked:bg-primary peer-checked:ring-2 peer-checked:ring-white peer-checked:ring-inset"
                ></span>
                <span>No necesitaremos bus</span>
              </label>
            </div>
          </div>
          <div id="bus-count-wrapper" class="hidden" hidden aria-hidden="true">
            <label
              class="text-sm leading-none peer-disabled:cursor-not-allowed peer-disabled:opacity-70 text-foreground font-medium"
              for="bus_count">¿Cuántas personas irán en bus?</label
            ><input
              type="number"
              class="flex h-10 rounded-md border px-3 py-2 text-base ring-offset-background file:border-0 file:bg-transparent file:text-sm file:font-medium file:text-foreground placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50 md:text-sm mt-2 w-24 bg-background border-border text-foreground focus:border-primary"
              id="bus_count"
              name="bus_count"
              min="1"
              max="10"
              value="1"
              disabled
            />
            <p class="mt-2 text-sm text-muted-foreground font-body">
              No puede ser mayor que el número total de asistentes.
            </p>
          </div>
        </div>
        <div class="space-y-4">
          <div class="flex items-center gap-2">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="lucide lucide-triangle-alert w-4 h-4 text-accent"
            >
              <path
                d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3"
              >
              </path>
              <path d="M12 9v4"></path>
              <path d="M12 17h.01"></path>
            </svg>
            <label
              class="peer-disabled:cursor-not-allowed peer-disabled:opacity-70 text-base text-foreground font-medium"
              >Alergias e intolerancias alimentarias
            </label>
          </div>
          <p class="text-sm text-muted-foreground font-body">
            Es muy importante para nosotros conocer cualquier restricción
            alimentaria. Selecciona las que apliquen:
          </p>
          <div class="grid grid-cols-2 gap-3">
            <label
              class="flex items-center gap-2 font-medium text-sm cursor-pointer text-foreground"
            >
              <input
                type="checkbox"
                id="allergy_gluten"
                name="allergy_gluten"
                class="peer sr-only"
              />
              <span
                class="flex h-4 w-4 shrink-0 items-center justify-center rounded-sm border border-primary bg-background text-transparent ring-offset-background transition-colors peer-focus-visible:ring-2 peer-focus-visible:ring-ring peer-focus-visible:ring-offset-2 peer-checked:bg-primary peer-checked:border-primary peer-checked:text-primary-foreground"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="h-3 w-3"
                >
                  <path d="M20 6 9 17l-5-5"></path>
                </svg>
              </span>
              <span>Sin gluten / Celíaco</span>
            </label>
            <label
              class="flex items-center gap-2 font-medium text-sm cursor-pointer text-foreground"
            >
              <input
                type="checkbox"
                id="allergy_lactose"
                name="allergy_lactose"
                class="peer sr-only"
              />
              <span
                class="flex h-4 w-4 shrink-0 items-center justify-center rounded-sm border border-primary bg-background text-transparent ring-offset-background transition-colors peer-focus-visible:ring-2 peer-focus-visible:ring-ring peer-focus-visible:ring-offset-2 peer-checked:bg-primary peer-checked:border-primary peer-checked:text-primary-foreground"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="h-3 w-3"
                >
                  <path d="M20 6 9 17l-5-5"></path>
                </svg>
              </span>
              <span>Sin lactosa</span>
            </label>
            <label
              class="flex items-center gap-2 font-medium text-sm cursor-pointer text-foreground"
            >
              <input
                type="checkbox"
                id="allergy_vegetarian"
                name="allergy_vegetarian"
                class="peer sr-only"
              />
              <span
                class="flex h-4 w-4 shrink-0 items-center justify-center rounded-sm border border-primary bg-background text-transparent ring-offset-background transition-colors peer-focus-visible:ring-2 peer-focus-visible:ring-ring peer-focus-visible:ring-offset-2 peer-checked:bg-primary peer-checked:border-primary peer-checked:text-primary-foreground"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="h-3 w-3"
                >
                  <path d="M20 6 9 17l-5-5"></path>
                </svg>
              </span>
              <span>Vegetariano</span>
            </label>
            <label
              class="flex items-center gap-2 font-medium text-sm cursor-pointer text-foreground"
            >
              <input
                type="checkbox"
                id="allergy_vegan"
                name="allergy_vegan"
                class="peer sr-only"
              />
              <span
                class="flex h-4 w-4 shrink-0 items-center justify-center rounded-sm border border-primary bg-background text-transparent ring-offset-background transition-colors peer-focus-visible:ring-2 peer-focus-visible:ring-ring peer-focus-visible:ring-offset-2 peer-checked:bg-primary peer-checked:border-primary peer-checked:text-primary-foreground"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="h-3 w-3"
                >
                  <path d="M20 6 9 17l-5-5"></path>
                </svg>
              </span>
              <span>Vegano</span>
            </label>
            <label
              class="flex items-center gap-2 font-medium text-sm cursor-pointer text-foreground"
            >
              <input
                type="checkbox"
                id="allergy_nuts"
                name="allergy_nuts"
                class="peer sr-only"
              />
              <span
                class="flex h-4 w-4 shrink-0 items-center justify-center rounded-sm border border-primary bg-background text-transparent ring-offset-background transition-colors peer-focus-visible:ring-2 peer-focus-visible:ring-ring peer-focus-visible:ring-offset-2 peer-checked:bg-primary peer-checked:border-primary peer-checked:text-primary-foreground"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="h-3 w-3"
                >
                  <path d="M20 6 9 17l-5-5"></path>
                </svg>
              </span>
              <span>Alergia a frutos secos</span>
            </label>
            <label
              class="flex items-center gap-2 font-medium text-sm cursor-pointer text-foreground"
            >
              <input
                type="checkbox"
                id="allergy_seafood"
                name="allergy_seafood"
                class="peer sr-only"
              />
              <span
                class="flex h-4 w-4 shrink-0 items-center justify-center rounded-sm border border-primary bg-background text-transparent ring-offset-background transition-colors peer-focus-visible:ring-2 peer-focus-visible:ring-ring peer-focus-visible:ring-offset-2 peer-checked:bg-primary peer-checked:border-primary peer-checked:text-primary-foreground"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="h-3 w-3"
                >
                  <path d="M20 6 9 17l-5-5"></path>
                </svg>
              </span>
              <span>Alergia a mariscos</span>
            </label>
          </div>
          <div>
            <label
              class="peer-disabled:cursor-not-allowed peer-disabled:opacity-70 text-sm text-foreground font-medium"
              for="allergy_other">Otras alergias o restricciones:</label
            ><input
              class="flex h-10 w-full rounded-md border px-3 py-2 text-base ring-offset-background file:border-0 file:bg-transparent file:text-sm file:font-medium file:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50 md:text-sm mt-2 bg-background border-border text-foreground placeholder:text-muted-foreground focus:border-primary"
              id="allergy_other"
              placeholder="Ej: alergia al huevo, intolerancia a la fructosa..."
              value=""
              name="allergy_other"
            />
          </div>
        </div>
      </fieldset>
      <div>
        <label
          class="text-sm leading-none peer-disabled:cursor-not-allowed peer-disabled:opacity-70 text-foreground font-medium"
          for="message">Mensaje para los novios (opcional)</label
        ><textarea
          class="flex min-h-20 w-full rounded-md border px-3 py-2 text-sm ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50 mt-2 bg-background border-border text-foreground placeholder:text-muted-foreground focus:border-primary"
          id="message"
          name="message"
          placeholder="Escríbenos unas palabras..."
          rows="3"></textarea>
      </div>
      <button
        id="rsvp-submit"
        class="hover:cursor-pointer inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 [&_svg]:pointer-events-none [&_svg]:size-4 [&_svg]:shrink-0 h-10 px-4 py-2 w-full gap-2 bg-primary hover:bg-primary/90 text-primary-foreground font-medium"
        type="submit"
      >
        <span id="submit-default" class="inline-flex items-center gap-2">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="lucide lucide-send w-4 h-4"
          >
            <path
              d="M14.536 21.686a.5.5 0 0 0 .937-.024l6.5-19a.496.496 0 0 0-.635-.635l-19 6.5a.5.5 0 0 0-.024.937l7.93 3.18a2 2 0 0 1 1.112 1.11z"
            >
            </path>
            <path d="m21.854 2.147-10.94 10.939"></path>
          </svg>
          Enviar confirmación
        </span>
        <span id="submit-loading" class="hidden items-center gap-2">
          <span
            class="animate-spin inline-block size-4 border-2 border-current border-t-transparent text-primary-foreground rounded-full"
            role="status"
            aria-label="Cargando"></span>
          Enviando confirmación...
        </span>
      </button>
    </form>
  </div>
</section>

<script>
  // @ts-nocheck
  import { actions } from 'astro:actions';

  const form = document.querySelector('form');
  const attendanceDetails = document.getElementById('attendance-details');
  const attendingYes = document.getElementById('attending-yes');
  const attendingNo = document.getElementById('attending-no');
  const attendingOptions = document.querySelectorAll('input[name="attending"]');
  const guestCount = document.getElementById('guest_count');
  const busRequiredYes = document.getElementById('bus-required-yes');
  const busRequiredNo = document.getElementById('bus-required-no');
  const busOptions = document.querySelectorAll('input[name="bus_required"]');
  const busCountWrapper = document.getElementById('bus-count-wrapper');
  const busCount = document.getElementById('bus_count');
  const submitButton = document.getElementById('rsvp-submit');
  const submitDefault = document.getElementById('submit-default');
  const submitLoading = document.getElementById('submit-loading');
  const fieldControls = form
    ? Array.from(form.querySelectorAll('input, select, textarea'))
    : [];

  /**
   * @param {boolean} isSubmitting
   */
  const setSubmittingState = (isSubmitting) => {
    if (!(submitButton instanceof HTMLButtonElement)) {
      return;
    }

    submitButton.disabled = isSubmitting;
    submitButton.setAttribute('aria-busy', String(isSubmitting));

    submitDefault?.classList.toggle('hidden!', isSubmitting);
    submitLoading?.classList.toggle('hidden', !isSubmitting);
    submitLoading?.classList.toggle('inline-flex', isSubmitting);
  };

  const toggleAttendanceDetails = () => {
    if (
      !(attendanceDetails instanceof HTMLFieldSetElement) ||
      !(attendingNo instanceof HTMLInputElement)
    ) {
      return;
    }

    attendanceDetails.disabled = attendingNo.checked;
  };

  const syncBusCountInput = () => {
    if (
      !(guestCount instanceof HTMLInputElement) ||
      !(busCount instanceof HTMLInputElement)
    ) {
      return;
    }

    const maxGuests = Number.parseInt(guestCount.value || '1', 10);
    const safeMax = Number.isNaN(maxGuests) ? 1 : Math.max(maxGuests, 1);
    busCount.max = String(safeMax);

    const currentValue = Number.parseInt(busCount.value || '1', 10);
    if (Number.isNaN(currentValue) || currentValue < 1) {
      busCount.value = '1';
      return;
    }

    if (currentValue > safeMax) {
      busCount.value = String(safeMax);
    }
  };

  const toggleBusDetails = () => {
    const isAttending =
      attendingYes instanceof HTMLInputElement && attendingYes.checked;
    const needsBus =
      busRequiredYes instanceof HTMLInputElement && busRequiredYes.checked;
    const shouldShowBusCount = isAttending && needsBus;

    if (busRequiredNo instanceof HTMLInputElement && !isAttending) {
      busRequiredNo.checked = true;
    }

    if (busCountWrapper instanceof HTMLElement) {
      busCountWrapper.hidden = !shouldShowBusCount;
      busCountWrapper.setAttribute('aria-hidden', String(!shouldShowBusCount));
      busCountWrapper.classList.toggle('hidden', !shouldShowBusCount);
    }

    if (busCount instanceof HTMLInputElement) {
      busCount.disabled = !shouldShowBusCount;
      busCount.required = shouldShowBusCount;

      if (!shouldShowBusCount) {
        busCount.value = '1';
      }

      syncBusCountInput();
    }
  };

  const clearFieldErrors = () => {
    fieldControls.forEach((control) => {
      if (
        !(control instanceof HTMLInputElement) &&
        !(control instanceof HTMLSelectElement) &&
        !(control instanceof HTMLTextAreaElement)
      ) {
        return;
      }

      control.setCustomValidity('');
      control.classList.remove('border-red-500', 'focus:border-red-500');
    });
  };

  /**
   * @param {string} fieldName
   * @param {string} message
   */
  const setFieldError = (fieldName, message) => {
    if (!form || !fieldName || !message) return;

    const controls = form.querySelectorAll(`[name="${fieldName}"]`);
    if (!controls.length) return;

    controls.forEach((control) => {
      if (
        !(control instanceof HTMLInputElement) &&
        !(control instanceof HTMLSelectElement) &&
        !(control instanceof HTMLTextAreaElement)
      ) {
        return;
      }

      control.setCustomValidity(message);
      control.classList.add('border-red-500', 'focus:border-red-500');
    });

    const firstControl = controls[0];
    if (
      firstControl instanceof HTMLInputElement ||
      firstControl instanceof HTMLSelectElement ||
      firstControl instanceof HTMLTextAreaElement
    ) {
      firstControl.reportValidity();
      firstControl.focus();
    }
  };

  /**
   * @param {unknown} actionError
   * @returns {Record<string, string>}
   */
  const extractFieldErrors = (actionError) => {
    /** @type {Record<string, string>} */
    const fieldErrors = Object.create(null);
    if (!actionError || typeof actionError !== 'object') return fieldErrors;

    const actionErrorRecord = actionError;

    const fieldsCandidate =
      actionErrorRecord?.fields ??
      actionErrorRecord?.data?.fields ??
      actionErrorRecord?.zodError?.fieldErrors ??
      actionErrorRecord?.data?.zodError?.fieldErrors;

    if (fieldsCandidate && typeof fieldsCandidate === 'object') {
      Object.entries(fieldsCandidate).forEach(([key, value]) => {
        if (!value) return;
        if (Array.isArray(value) && value.length > 0) {
          fieldErrors[key] = String(value[0]);
          return;
        }

        if (typeof value === 'string') {
          fieldErrors[key] = value;
        }
      });
    }

    const issuesCandidate =
      actionErrorRecord?.issues ??
      actionErrorRecord?.data?.issues ??
      actionErrorRecord?.zodError?.issues ??
      actionErrorRecord?.data?.zodError?.issues;

    if (Array.isArray(issuesCandidate)) {
      issuesCandidate.forEach((issue) => {
        const issuePath = issue?.path;
        const path = Array.isArray(issuePath) ? issuePath[0] : undefined;
        const message = issue?.message;

        if (
          typeof path === 'string' &&
          typeof message === 'string' &&
          !fieldErrors[path]
        ) {
          fieldErrors[path] = message;
        }
      });
    }

    return fieldErrors;
  };

  attendingOptions.forEach((option) => {
    option.addEventListener('change', () => {
      toggleAttendanceDetails();
      toggleBusDetails();
    });
  });

  busOptions.forEach((option) => {
    option.addEventListener('change', toggleBusDetails);
  });

  guestCount?.addEventListener('input', syncBusCountInput);

  fieldControls.forEach((control) => {
    control.addEventListener('input', () => {
      if (
        !(control instanceof HTMLInputElement) &&
        !(control instanceof HTMLSelectElement) &&
        !(control instanceof HTMLTextAreaElement)
      ) {
        return;
      }

      control.setCustomValidity('');
      control.classList.remove('border-red-500', 'focus:border-red-500');
    });

    control.addEventListener('change', () => {
      if (
        !(control instanceof HTMLInputElement) &&
        !(control instanceof HTMLSelectElement) &&
        !(control instanceof HTMLTextAreaElement)
      ) {
        return;
      }

      control.setCustomValidity('');
      control.classList.remove('border-red-500', 'focus:border-red-500');
    });
  });

  toggleAttendanceDetails();
  syncBusCountInput();
  toggleBusDetails();

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    clearFieldErrors();
    setSubmittingState(true);

    const { data, error } = await actions.confirmAssist(new FormData(form));

    if (error) {
      setSubmittingState(false);

      const mappedErrors = extractFieldErrors(error);
      const entries = Object.entries(mappedErrors);
      if (entries.length > 0) {
        const [firstField, firstMessage] = entries[0];
        setFieldError(firstField, firstMessage);
        entries.slice(1).forEach(([field, message]) => {
          setFieldError(field, message);
        });
      }

      window.dispatchEvent(
        new CustomEvent('toast:show', {
          detail: {
            type: 'error',
            message:
              entries.length > 0
                ? 'Revisa los campos marcados en el formulario'
                : 'No se pudo enviar la confirmación',
          },
        })
      );
      return;
    }

    window.dispatchEvent(
      new CustomEvent('toast:show', {
        detail: {
          type: 'success',
          message: data?.message ?? 'Confirmación enviada correctamente',
        },
      })
    );

    form.reset();
    toggleAttendanceDetails();
    syncBusCountInput();
    toggleBusDetails();
    setSubmittingState(false);
  });
</script>
