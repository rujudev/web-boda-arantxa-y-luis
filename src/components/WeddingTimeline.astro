---
import TimelineStep from "./TimelineStep.astro";
import Beer from "./icons/Beer.astro";
import Heart from './icons/Heart.astro';
import UtensilsCrossed from "./icons/UtensilsCrossed.astro";
import Wine from "./icons/Wine.astro";
---

<section class="py-20 px-6 md:py-28 md:px-12 bg-ivory">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16" style="opacity: 1; transform: none;">
      <h2 class="font-script text-5xl md:text-6xl text-foreground mb-2">Programa del día</h2>
      <p class="text-muted-foreground font-body tracking-wide">Nuestra celebración paso a paso</p>
    </div>
    <div class="relative">
      <div class="hidden md:flex md:flex-col md:items-center md:justify-center">
        <div class="absolute left-0 right-0 h-px bg-border"></div>
        <div class="grid grid-cols-4 gap-2 items-center justify-items-center w-full">
          <TimelineStep hour="20:15" title="Ceremonia" description="Nos damos el sí" Icon={Heart} />
          <TimelineStep hour="21:00" title="Cóctel" description="Brindis y aperitivos" Icon={Wine} />
          <TimelineStep hour="21:30" title="Cena" description="Banquete nupcial" Icon={UtensilsCrossed} />
          <TimelineStep hour="01:00" title="Barra libre" description="Disfruta de la música y los cócteles" Icon={Beer} />
        </div>
      </div>
    </div>
    <div class="md:hidden relative">
      <div class="absolute left-6 top-0 bottom-0 w-px bg-border"></div>
      <div class="space-y-6">
        <TimelineStep isMobileView={true} hour="20:15" title="Ceremonia" description="Nos damos el sí" Icon={Heart} />
        <TimelineStep isMobileView={true} hour="21:00" title="Cóctel" description="Brindis y aperitivos" Icon={Wine} />
        <TimelineStep isMobileView={true} hour="21:30" title="Cena" description="Banquete nupcial" Icon={UtensilsCrossed} />
        <TimelineStep isMobileView={true} hour="01:00" title="Barra libre" description="Disfruta de la música y los cócteles" Icon={Beer} />
      </div>
    </div>
  </div>
</section>
