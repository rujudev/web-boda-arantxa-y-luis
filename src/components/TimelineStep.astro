---
const { hour, title, description, isMobileView, Icon } = Astro.props;
---

{
  isMobileView ? (
    <div
      class="flex items-start gap-4 pl-1"
      style="opacity: 1; transform: none;"
    >
      <div class="w-11 h-11 rounded-full bg-background border-2 border-border flex items-center justify-center text-primary shrink-0 shadow-soft z-10">
        <Icon />
      </div>
      <div class="flex-1 pt-1">
        <div class="flex items-baseline gap-3 mb-0.5">
          <span class="bg-primary text-primary-foreground px-2 py-0.5 rounded text-xs font-display font-medium">
            {hour}h
          </span>
          <h3 class="font-display text-lg text-foreground">{title}</h3>
        </div>
        <p class="text-muted-foreground font-body text-sm">{description}</p>
      </div>
    </div>
  ) : (
    <div
      class="flex flex-col items-center text-center group w-fit"
      style="opacity: 1; transform: none;"
    >
      <div class="bg-primary text-primary-foreground px-3 py-1.5 rounded-full text-sm font-display font-medium mb-4">
        {hour}h
      </div>
      <div class="w-14 h-14 rounded-full bg-background border-2 border-border flex items-center justify-center text-primary mb-4 shadow-soft group-hover:border-primary group-hover:scale-110 transition-all duration-300 z-10">
        <Icon />
      </div>
      <h3 class="font-display text-base lg:text-lg text-foreground mb-1 leading-tight">
        {title}
      </h3>
      <p class="text-muted-foreground font-body text-xs leading-relaxed px-1">
        {description}
      </p>
    </div>
  )
}
