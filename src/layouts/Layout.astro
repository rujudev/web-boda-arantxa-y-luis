---
import cover from '../assets/the_irrepresibles.webp';
import '../output.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/gem-ring.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>Boda Arantxa y Luis</title>
  </head>
  <body>
    <slot />
    <div
      class="fixed max-md:top-0 md:bottom-0 right-0 flex items-center flex-col justify-center z-30 p-4"
    >
      <div
        id="music-card"
        role="button"
        tabindex="0"
        aria-label="Activar o pausar musica"
        class="w-fit max-w-xs flex flex-row items-center bg-background px-2 py-2 rounded-md shadow-lg"
      >
        <div
          class="relative flex items-center max-md:h-10 md:w-18 md:h-14 min-w-14"
        >
          <img
            src={cover.src}
            alt=""
            class="w-full h-full rounded-md object-cover"
          />
          <div
            class="absolute inset-0 flex flex-row justify-center items-center"
          >
            <div class="bar bg-white h-1.5 w-1 md:h-3 md:w-1.5 rounded-lg m-1"
            ></div>
            <div class="bar bg-white h-1.5 w-1 md:h-3 md:w-1.5 rounded-lg m-1"
            ></div>
            <div class="bar bg-white h-1.5 w-1 md:h-3 md:w-1.5 rounded-lg m-1"
            ></div>
          </div>
        </div>
        <div class="w-auto flex flex-col ml-3 overflow-hidden">
          <p
            class="max-md:text-sm md:text-xl truncate whitespace-nowrap overflow-hidden"
            >In This Shirt</p
          >
          <p
            class="max-md:text-xs text-gray-600 truncate whitespace-nowrap overflow-hidden"
            >THE IRREPRESIBLES</p
          >
        </div>
        <div
          id="music-state-pill"
          class="ml-3 rounded-full leading-none"
          aria-live="polite"
        >
          <svg
            id="music-icon-play"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="lucide lucide-circle-play-icon lucide-circle-play"
            aria-hidden="true"
          >
            <path
              d="M9 9.003a1 1 0 0 1 1.517-.859l4.997 2.997a1 1 0 0 1 0 1.718l-4.997 2.997A1 1 0 0 1 9 14.996z"
            ></path>
            <circle cx="12" cy="12" r="10"></circle>
          </svg>
          <svg
            id="music-icon-pause"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="hidden lucide lucide-circle-pause-icon lucide-circle-pause"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="10" x2="10" y1="15" y2="9"></line>
            <line x1="14" x2="14" y1="15" y2="9"></line>
          </svg>
        </div>
      </div>
    </div>
    <script is:inline src="/node_modules/preline/dist/preline.js"></script>
    <script src="/src/music.js" type="module"></script>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }

  #music-card {
    cursor: pointer;
    user-select: none;
  }

  #music-card .bar {
    transform-origin: bottom;
    animation: equalizer 0.9s ease-in-out infinite alternate;
    animation-play-state: paused;
    opacity: 0.4;
  }

  #music-state-pill {
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.7);
    transition:
      background-color 0.2s ease,
      color 0.2s ease;
  }

  #music-state-pill svg {
    width: 20px;
    height: 20px;
  }

  #music-state-pill.is-playing {
    background: rgba(0, 0, 0, 0.85);
    color: #fff;
  }

  #music-card.is-playing .bar {
    animation-play-state: running;
    opacity: 1;
  }

  #music-card .bar:nth-child(2) {
    animation-delay: 0.15s;
  }

  #music-card .bar:nth-child(3) {
    animation-delay: 0.3s;
  }

  @keyframes equalizer {
    from {
      transform: scaleY(0.4);
    }
    to {
      transform: scaleY(1);
    }
  }
</style>
